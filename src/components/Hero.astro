---
// Sección principal de presentación
import i18nEs from '../data/i18n/es.json';
import i18nEn from '../data/i18n/en.json';

const allData = {
  es: i18nEs.hero,
  en: i18nEn.hero,
};

const startYear = 2020;
const currentYear = new Date().getFullYear();
const yearsOfExperience = currentYear - startYear;

// Por defecto inglés
const hero = i18nEn.hero;
---

<section id="inicio" class="relative min-h-screen flex items-center justify-center pt-20 pb-10">
  <!-- Elementos decorativos -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-20 -right-20 w-96 h-96 bg-green-500/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-20 -left-20 w-80 h-80 bg-green-600/5 rounded-full blur-3xl"></div>
  </div>
  
  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center max-w-4xl mx-auto">
      <!-- Saludo inicial -->
      <div class="mb-6 animate-fade-in">
        <span class="inline-block px-4 py-2 bg-green-500/10 border border-green-500/20 rounded-full text-green-400 text-sm font-medium" data-i18n="hero-greeting">
          {hero.greeting}
        </span>
      </div>
      
      <!-- Nombre y título principal -->
      <h1 class="text-5xl md:text-7xl font-bold mb-6 animate-slide-up">
        <span class="bg-gradient-to-r from-white via-gray-100 to-green-400 bg-clip-text text-transparent">
          {hero.name}
        </span>
      </h1>
      
      <!-- Descripción -->
      <p class="text-xl md:text-2xl text-gray-300 mb-8 animate-slide-up animation-delay-200">
        <span data-i18n="hero-description">{hero.description}</span>
        <br>
        <span class="text-green-400"><span data-i18n="hero-specialization">{hero.specialization}</span> <span class="font-bold text-green-300" data-i18n="hero-framework">{hero.framework}</span>.</span>
      </p>
      
      <!-- Estadísticas rápidas -->
      <div class="flex flex-wrap justify-center gap-8 mb-12 animate-slide-up animation-delay-400">
        <div class="text-center">
          <div class="text-3xl font-bold text-green-400">{yearsOfExperience}+</div>
          <div class="text-gray-400 text-sm" data-i18n="hero-stats-experience">
            {hero.stats.experience.label}
          </div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-green-400">25+</div>
          <div class="text-gray-400 text-sm" data-i18n="hero-stats-projects">
            {hero.stats.projects.label}
          </div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-green-400">100%</div>
          <div class="text-gray-400 text-sm" data-i18n="hero-stats-clients">
            {hero.stats.clients.label}
          </div>
        </div>
      </div>
      
      <!-- Botones de acción -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-slide-up animation-delay-600">
        <a href="#proyectos" 
           class="group px-8 py-4 bg-gradient-to-r from-green-500 to-green-600 rounded-full text-white font-medium hover:from-green-600 hover:to-green-700 transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-green-500/25 flex items-center justify-center gap-2" data-i18n="hero-cta-projects">
          {hero.cta.projects}
          <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
        
        <a href="https://drive.google.com/file/d/1exx5OEzN2e3jiAPk1rJ1sKtPgZKwfXux/view?usp=drive_link" target="_blank" rel="noopener noreferrer"
           class="px-8 py-4 border-2 border-green-500/50 rounded-full text-green-400 font-medium hover:bg-green-500/10 hover:border-green-400 transition-all duration-300 flex items-center justify-center gap-2" data-i18n="hero-cta-cv">
          {hero.cta.cv}
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
        </a>
      </div>
    </div>
    
    <!-- Indicador de scroll -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
      <a href="#experiencia" class="text-gray-400 hover:text-green-400 transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  @keyframes slide-up {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-fade-in {
    animation: fade-in 1s ease-out;
  }
  
  .animate-slide-up {
    animation: slide-up 1s ease-out;
  }
  
  .animation-delay-200 {
    animation-delay: 0.2s;
    animation-fill-mode: both;
  }
  
  .animation-delay-400 {
    animation-delay: 0.4s;
    animation-fill-mode: both;
  }
  
  .animation-delay-600 {
    animation-delay: 0.6s;
    animation-fill-mode: both;
  }
</style>

<script define:vars={{ allData }}>
  function updateHero() {
    const lang = localStorage.getItem('lang') || 'en';
    const data = allData[lang];
    
    if (!data) return;
    
    // Actualizar textos
    const elements = {
      'hero-greeting': data.greeting,
      'hero-description': data.description,
      'hero-specialization': data.specialization,
      'hero-framework': data.framework,
      'hero-stats-experience': data.stats.experience.label,
      'hero-stats-projects': data.stats.projects.label,
      'hero-stats-clients': data.stats.clients.label,
      'hero-cta-projects': data.cta.projects,
      'hero-cta-cv': data.cta.cv,
    };
    
    Object.entries(elements).forEach(([key, text]) => {
      const el = document.querySelector(`[data-i18n="${key}"]`);
      if (el) el.textContent = text;
    });
  }
  
  // Escuchar evento de cambio de idioma
  window.addEventListener('languageChanged', () => {
    updateHero();
  });
  
  document.addEventListener('DOMContentLoaded', updateHero);
  if (document.readyState !== 'loading') {
    updateHero();
  }
</script>