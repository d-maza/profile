---
// Sección de proyectos destacados
import projectsEs from '../data/projects-es.json';
import projectsEn from '../data/projects-en.json';
import i18nEs from '../data/i18n/es.json';
import i18nEn from '../data/i18n/en.json';

const allData = {
  es: { projects: projectsEs.projects, i18n: i18nEs.projects },
  en: { projects: projectsEn.projects, i18n: i18nEn.projects },
};

// Por defecto español
const { projects } = projectsEs;
const i18n = i18nEs.projects;
---

<section id="proyectos" class="py-20 relative">
  <div class="container mx-auto px-6">
    <!-- Título de la sección -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">
        <span class="bg-gradient-to-r from-green-400 to-green-600 bg-clip-text text-transparent" data-i18n="projects-title">
          {i18n.title}
        </span>
      </h2>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto" data-i18n="projects-subtitle">
        {i18n.subtitle}
      </p>
    </div>
    
    <!-- Grid de proyectos -->
    <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-8" id="projects-grid">
      {projects.map((project, index) => (
        <div class={`group bg-dark-800/50 backdrop-blur-sm border border-green-500/20 rounded-xl overflow-hidden hover:border-green-400/40 transition-all duration-300 hover:transform hover:scale-105 ${index >= 3 ? 'hidden extra-project' : ''}`}>
          <!-- Imagen del proyecto -->
          <div class="relative h-48 bg-gradient-to-br from-green-500/20 to-green-700/20 flex items-center justify-center overflow-hidden">
            <div class="absolute inset-0 bg-grid-pattern opacity-20"></div>
            <div class="relative z-10 w-full h-full">
              {project.svg ? (
                <img src={project.svg} alt={project.name} class={`w-full h-full object-cover ${project.id === 9 || project.id === 7 ? 'object-[center_20%]' : 'object-top'}`} />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-6xl">{project.emoji}</div>
              )}
            </div>
            <div class="absolute top-4 right-4 bg-green-500/10 backdrop-blur-sm rounded-full px-3 py-1 z-20">
              <span class="text-green-400 text-sm font-medium">{project.category}</span>
            </div>
          </div>
          
          <div class="p-6">
            <h3 class="text-xl font-semibold text-white mb-3">{project.name}</h3>
            <p class="text-gray-300 text-sm mb-4">
              {project.description}
            </p>
            
            <!-- Tecnologías -->
            <div class="flex flex-wrap gap-2 mb-4">
              {project.technologies.map((tech) => (
                <span class="bg-dark-700 text-green-400 px-2 py-1 rounded text-xs">{tech}</span>
              ))}
            </div>
            
            <!-- Enlaces -->
            <div class="flex gap-3">
              <a href={project.links.demo} class="flex items-center gap-2 text-green-400 hover:text-green-300 transition-colors text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                </svg>
                Ver demo
              </a>
              <a href={project.links.code} class="flex items-center gap-2 text-gray-400 hover:text-green-400 transition-colors text-sm">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                Código
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <!-- Botón para ver más proyectos -->
    <div class="text-center mt-12">
      <button id="view-all-btn"
         class="inline-flex items-center gap-2 px-8 py-3 border-2 border-green-500/50 rounded-full text-green-400 font-medium hover:bg-green-500/10 hover:border-green-400 transition-all duration-300">
        <span data-i18n="projects-viewAll">{i18n.viewAll}</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </button>
    </div>
  </div>
</section>

<script define:vars={{ allData }}>
  let showingAll = false;
  
  function updateProjects() {
    const lang = localStorage.getItem('lang') || 'en';
    const data = allData[lang];
    
    if (!data) return;
    
    const titleEl = document.querySelector('[data-i18n="projects-title"]');
    const subtitleEl = document.querySelector('[data-i18n="projects-subtitle"]');
    const viewAllEl = document.querySelector('[data-i18n="projects-viewAll"]');
    
    if (titleEl) titleEl.textContent = data.i18n.title;
    if (subtitleEl) subtitleEl.textContent = data.i18n.subtitle;
    if (viewAllEl) viewAllEl.textContent = showingAll ? data.i18n.viewLess : data.i18n.viewAll;
  }
  
  function toggleProjects() {
    const extraProjects = document.querySelectorAll('.extra-project');
    const btn = document.getElementById('view-all-btn');
    const lang = localStorage.getItem('lang') || 'en';
    const data = allData[lang];
    
    showingAll = !showingAll;
    
    extraProjects.forEach(project => {
      if (showingAll) {
        project.classList.remove('hidden');
      } else {
        project.classList.add('hidden');
      }
    });
    
    const textEl = btn.querySelector('[data-i18n="projects-viewAll"]');
    if (textEl && data) {
      textEl.textContent = showingAll ? data.i18n.viewLess : data.i18n.viewAll;
    }
    
    // Scroll suave hacia arriba cuando se ocultan
    if (!showingAll) {
      document.getElementById('proyectos').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }
  
  window.addEventListener('languageChanged', () => {
    updateProjects();
  });
  
  document.addEventListener('DOMContentLoaded', () => {
    updateProjects();
    const btn = document.getElementById('view-all-btn');
    if (btn) {
      btn.addEventListener('click', toggleProjects);
    }
  });
  
  if (document.readyState !== 'loading') {
    updateProjects();
    const btn = document.getElementById('view-all-btn');
    if (btn) {
      btn.addEventListener('click', toggleProjects);
    }
  }
</script>