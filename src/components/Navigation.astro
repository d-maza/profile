---
// Navegación principal
import i18nEs from '../data/i18n/es.json';
import i18nEn from '../data/i18n/en.json';

const allData = {
  es: { navigation: i18nEs.navigation },
  en: { navigation: i18nEn.navigation },
};

const nav = i18nEn.navigation;
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-dark-950/80 backdrop-blur-md border-b border-green-500/20">
  <div class="container mx-auto px-6 py-4">
    <div class="flex items-center justify-between">
      <!-- Logo/Nombre -->
      <div class="text-2xl font-bold bg-gradient-to-r from-green-400 to-green-600 bg-clip-text text-transparent">
        davidmaza.dev
      </div>
      
      <!-- Menú de navegación -->
      <div class="hidden md:flex items-center space-x-8">
        <a href="#inicio" class="nav-link text-gray-300 hover:text-green-400 transition-colors duration-300" data-i18n="nav-home">
          {nav.links.home}
        </a>
        <a href="#experiencia" class="nav-link text-gray-300 hover:text-green-400 transition-colors duration-300" data-i18n="nav-experience">
          {nav.links.experience}
        </a>
        <a href="#proyectos" class="nav-link text-gray-300 hover:text-green-400 transition-colors duration-300" data-i18n="nav-projects">
          {nav.links.projects}
        </a>
        <a href="#formacion" class="nav-link text-gray-300 hover:text-green-400 transition-colors duration-300" data-i18n="nav-education">
          {nav.links.education}
        </a>
        <a href="#contacto" class="nav-link text-gray-300 hover:text-green-400 transition-colors duration-300" data-i18n="nav-contact">
          {nav.links.contact}
        </a>
      </div>
      
      <!-- Selector de idioma -->
      <div class="hidden md:flex items-center space-x-2">
        <button data-lang="es" class="lang-btn w-9 h-9 rounded-full bg-dark-800 border-2 border-transparent hover:border-green-400 transition-all duration-300 hover:scale-110 flex items-center justify-center font-semibold text-sm text-gray-300 hover:text-green-400" title="Español">
          ES
        </button>
        <button data-lang="en" class="lang-btn w-9 h-9 rounded-full bg-dark-800 border-2 border-transparent hover:border-green-400 transition-all duration-300 hover:scale-110 flex items-center justify-center font-semibold text-sm text-gray-300 hover:text-green-400" title="English">
          EN
        </button>
      </div>
      
      <!-- Botón de contacto -->
      <div class="hidden md:block">
        <a href="#contacto" 
           class="px-6 py-2 bg-gradient-to-r from-green-500 to-green-600 rounded-full text-white font-medium hover:from-green-600 hover:to-green-700 transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-green-500/25" data-i18n="nav-cta">
          {nav.cta}
        </a>
      </div>
      
      <!-- Menú móvil -->
      <div class="md:hidden">
        <button id="mobile-menu-btn" class="text-gray-300 hover:text-green-400 focus:outline-none focus:text-green-400">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
    
    <!-- Menú móvil desplegable -->
    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 border-t border-green-500/20 pt-4">
      <div class="flex flex-col space-y-4">
        <a href="#inicio" class="text-gray-300 hover:text-green-400 transition-colors duration-300" data-i18n="nav-home">{nav.links.home}</a>
        <a href="#experiencia" class="text-gray-300 hover:text-green-400 transition-colors duration-300" data-i18n="nav-experience">{nav.links.experience}</a>
        <a href="#proyectos" class="text-gray-300 hover:text-green-400 transition-colors duration-300" data-i18n="nav-projects">{nav.links.projects}</a>
        <a href="#formacion" class="text-gray-300 hover:text-green-400 transition-colors duration-300" data-i18n="nav-education">{nav.links.education}</a>
        <a href="#contacto" class="text-gray-300 hover:text-green-400 transition-colors duration-300" data-i18n="nav-contact">{nav.links.contact}</a>
        
        <!-- Selector de idioma móvil -->
        <div class="flex items-center justify-center space-x-4 pt-2 border-t border-green-500/20">
          <button data-lang="es" class="lang-btn w-14 h-14 rounded-full bg-dark-800 border-2 border-transparent hover:border-green-400 transition-all duration-300 hover:scale-110 flex items-center justify-center font-bold text-lg text-gray-300 hover:text-green-400" title="Español">
            ES
          </button>
          <button data-lang="en" class="lang-btn w-14 h-14 rounded-full bg-dark-800 border-2 border-transparent hover:border-green-400 transition-all duration-300 hover:scale-110 flex items-center justify-center font-bold text-lg text-gray-300 hover:text-green-400" title="English">
            EN
          </button>
        </div>
      </div>
    </div>
  </div>
</nav>

<script define:vars={{allData}} is:inline>
  // Detectar idioma del navegador automáticamente
  (function initLanguage() {
    if (!localStorage.getItem('lang')) {
      const browserLang = navigator.language.toLowerCase();
      const lang = browserLang.startsWith('es') ? 'es' : 'en';
      localStorage.setItem('lang', lang);
    }
  })();

  // Funcionalidad del menú móvil
  document.addEventListener('DOMContentLoaded', function() {
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    
    if (mobileMenuBtn && mobileMenu) {
      mobileMenuBtn.addEventListener('click', function() {
        mobileMenu.classList.toggle('hidden');
      });
      
      // Cerrar menú al hacer clic en un enlace
      const mobileLinks = mobileMenu.querySelectorAll('a');
      mobileLinks.forEach(link => {
        link.addEventListener('click', function() {
          mobileMenu.classList.add('hidden');
        });
      });
    }
    
    // Función para actualizar la navegación
    function updateNavigation() {
      const lang = localStorage.getItem('lang') || 'en';
      const data = allData[lang];
      
      if (!data) return;
      
      const elements = {
        'nav-home': data.navigation.links.home,
        'nav-experience': data.navigation.links.experience,
        'nav-projects': data.navigation.links.projects,
        'nav-education': data.navigation.links.education,
        'nav-contact': data.navigation.links.contact,
        'nav-cta': data.navigation.cta,
      };
      
      Object.entries(elements).forEach(([key, text]) => {
        const els = document.querySelectorAll(`[data-i18n="${key}"]`);
        els.forEach(el => {
          el.textContent = text;
        });
      });
    }
    
    // Escuchar evento de cambio de idioma
    window.addEventListener('languageChanged', () => {
      updateNavigation();
    });
    
    updateNavigation();
    
    // Selector de idioma
    const langButtons = document.querySelectorAll('.lang-btn');
    const currentLang = localStorage.getItem('lang') || 'en';
    
    // Resaltar idioma actual
    langButtons.forEach(btn => {
      const button = btn;
      if (button.getAttribute('data-lang') === currentLang) {
        button.classList.add('border-green-400', 'scale-110', 'text-green-400');
        button.classList.remove('text-gray-300');
      }
      
      button.addEventListener('click', function() {
        const selectedLang = button.getAttribute('data-lang');
        if (!selectedLang) return;
        
        localStorage.setItem('lang', selectedLang);
        
        // Actualizar botones activos
        langButtons.forEach(b => {
          b.classList.remove('border-green-400', 'scale-110', 'text-green-400');
          b.classList.add('text-gray-300');
        });
        document.querySelectorAll('[data-lang="' + selectedLang + '"]').forEach(b => {
          b.classList.add('border-green-400', 'scale-110', 'text-green-400');
          b.classList.remove('text-gray-300');
        });
        
        // Disparar evento personalizado para actualizar contenido
        window.dispatchEvent(new CustomEvent('languageChanged', { detail: { lang: selectedLang } }));
      });
    });
  });
</script>